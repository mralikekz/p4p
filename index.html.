<!DOCTYPE html>
<html lang="en" data-theme="dark" data-lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>UFC P4P RATING — Pi Network</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Rajdhani:wght@400;500;600;700&family=Share+Tech+Mono&display=swap" rel="stylesheet">
<style>
/* ══════════════════════════════════════
   THEME VARIABLES
══════════════════════════════════════ */
:root {
  --gold: #f0b429; --gold2: #ffd166;
  --pi: #7c3aed; --pi2: #8b5cf6; --pi3: #a78bfa; --pi4: #c4b5fd;
  --red: #e63946; --green: #10b981;
  --trans: 0.22s ease;
}
[data-theme="dark"] {
  --bg: #060609; --bg2: #0d0d14; --card: #111118; --card2: #16161f; --card3: #1c1c27;
  --border: rgba(240,180,41,0.12); --border2: rgba(139,92,246,0.2); --border3: rgba(255,255,255,0.06);
  --text: #e8e8f2; --text2: #b0b0cc; --muted: #5a5a78; --muted2: #8888aa;
  --shadow: 0 4px 24px rgba(0,0,0,0.5);
  --nav-bg: rgba(6,6,9,0.97);
  --glow1: rgba(124,58,237,0.09); --glow2: rgba(240,180,41,0.06);
  --fighter-bg: #0a0a10;
  --champ-bg: linear-gradient(135deg,rgba(240,180,41,0.08),rgba(124,58,237,0.06));
  --pi-box-bg: rgba(124,58,237,0.1);
  --wallet-bg: rgba(255,255,255,0.03);
  --overlay-bg: rgba(0,0,0,0.88);
  --toast-bg: #1a1a2e;
  --img-bg: #1a1a24;
  --no-photo: #2a2a38;
}
[data-theme="light"] {
  --bg: #f4f4f8; --bg2: #eeeef4; --card: #ffffff; --card2: #f8f8fc; --card3: #efeff6;
  --border: rgba(124,58,237,0.15); --border2: rgba(124,58,237,0.25); --border3: rgba(0,0,0,0.08);
  --text: #18182a; --text2: #444460; --muted: #9090b0; --muted2: #666688;
  --shadow: 0 2px 16px rgba(124,58,237,0.1);
  --nav-bg: rgba(244,244,248,0.97);
  --glow1: rgba(124,58,237,0.06); --glow2: rgba(240,180,41,0.04);
  --fighter-bg: #f0f0f8;
  --champ-bg: linear-gradient(135deg,rgba(240,180,41,0.1),rgba(124,58,237,0.07));
  --pi-box-bg: rgba(124,58,237,0.07);
  --wallet-bg: rgba(124,58,237,0.05);
  --overlay-bg: rgba(0,0,20,0.7);
  --toast-bg: #1a1a2e;
  --img-bg: #e0e0ec;
  --no-photo: #d0d0e0;
}

/* ══════════════════════════════════════
   BASE
══════════════════════════════════════ */
* { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior:smooth; }
body {
  background:var(--bg); color:var(--text);
  font-family:'Rajdhani',sans-serif; font-weight:500;
  min-height:100vh; overflow-x:hidden;
  transition: background var(--trans), color var(--trans);
}
.bg-glow {
  position:fixed; inset:0; pointer-events:none; z-index:0;
  background: radial-gradient(ellipse 80% 50% at 10% 5%, var(--glow1) 0%, transparent 55%),
              radial-gradient(ellipse 60% 40% at 90% 90%, var(--glow2) 0%, transparent 55%);
}

header {
  position:relative; z-index:10;
  padding:28px 20px 22px; text-align:center;
  border-bottom:1px solid var(--border);
  background:linear-gradient(180deg, var(--glow1) 0%, transparent 100%);
}
.header-top { display:flex; justify-content:space-between; align-items:center; max-width:900px; margin:0 auto 12px; }
.pi-tag {
  display:inline-flex; align-items:center; gap:7px;
  background:rgba(124,58,237,0.15); border:1px solid rgba(124,58,237,0.4);
  border-radius:100px; padding:4px 14px;
  font-size:11px; letter-spacing:3px; text-transform:uppercase; color:var(--pi4);
}
.pi-dot { width:6px;height:6px;background:var(--pi3);border-radius:50%;animation:blink 2s infinite; }
@keyframes blink{0%,100%{opacity:1}50%{opacity:.3}}

.header-controls { display:flex; align-items:center; gap:8px; }
.lang-select {
  background:var(--card); border:1px solid var(--border); color:var(--text);
  border-radius:6px; padding:5px 8px; font-family:'Rajdhani',sans-serif;
  font-size:13px; cursor:pointer; outline:none;
}
.theme-toggle {
  width:48px; height:26px; background:var(--card); border:1px solid var(--border);
  border-radius:13px; cursor:pointer; position:relative; transition:background .2s;
  flex-shrink:0;
}
.theme-toggle .knob {
  position:absolute; top:3px; left:3px; width:18px; height:18px;
  background:var(--pi3); border-radius:50%; transition:all .22s;
  display:flex; align-items:center; justify-content:center; font-size:10px;
}
[data-theme="light"] .theme-toggle .knob { left:25px; background:var(--gold); }

h1 {
  font-family:'Bebas Neue',sans-serif;
  font-size:clamp(48px,11vw,100px); letter-spacing:6px; line-height:.88;
  background:linear-gradient(135deg,#f0b429 0%,#fff 45%,#f0b429 100%);
  -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;
}
[data-theme="light"] h1 {
  background:linear-gradient(135deg,#c47a00 0%,#7c3aed 50%,#c47a00 100%);
  -webkit-background-clip:text; background-clip:text;
}
.h1-sub { font-family:'Bebas Neue',sans-serif; font-size:clamp(13px,2.5vw,20px); letter-spacing:7px; color:var(--muted2); margin-top:4px; }

.header-stats { display:flex; justify-content:center; gap:36px; margin-top:18px; flex-wrap:wrap; }
.hstat-val { font-family:'Bebas Neue',sans-serif; font-size:28px; color:var(--gold); letter-spacing:2px; }
.hstat-lbl { font-size:11px; letter-spacing:2px; text-transform:uppercase; color:var(--muted); }

.nav {
  position:sticky; top:0; z-index:50;
  background:var(--nav-bg); backdrop-filter:blur(16px);
  border-bottom:1px solid var(--border);
  overflow-x:auto; white-space:nowrap; scrollbar-width:none;
}
.nav-inner { display:inline-flex; padding:0 12px; }
.nav-btn {
  font-family:'Bebas Neue',sans-serif; font-size:17px; letter-spacing:2px;
  padding:13px 18px; border:none; background:none; color:var(--muted); cursor:pointer;
  border-bottom:3px solid transparent; transition:all .18s;
}
.nav-btn.active{ color:var(--gold); border-bottom-color:var(--gold); }

.page{ display:none; }
.page.active{ display:block; }
.p4p-page{ max-width:900px; margin:0 auto; padding:20px 14px 60px; position:relative; z-index:5; }
.section-label {
  font-family:'Bebas Neue',sans-serif; font-size:12px; letter-spacing:5px;
  text-transform:uppercase; color:var(--muted); padding:16px 0 12px;
  display:flex; align-items:center; gap:10px;
}
.section-label::after{ content:''; flex:1; height:1px; background:var(--border); }
.p4p-list{ display:flex; flex-direction:column; gap:6px; }

.p4p-card {
  display:flex; align-items:center; gap:12px; padding:10px 14px;
  background:var(--card); border:1px solid var(--border); border-radius:10px;
  transition:all .18s; position:relative; overflow:hidden;
}
.p4p-card.rank-1{ border-color:rgba(240,180,41,0.35); background:linear-gradient(90deg,rgba(240,180,41,0.04),var(--card)); }
.p4p-photo {
  width:52px; height:52px; border-radius:50%; overflow:hidden;
  background:var(--img-bg); border:2px solid var(--border); flex-shrink:0;
}
.p4p-photo img{ width:100%; height:100%; object-fit:cover; object-position:top; }
.p4p-photo .no-photo{ width:100%; height:100%; display:flex; align-items:center; justify-content:center; font-size:22px; background:var(--no-photo); }
.p4p-rank{ font-family:'Bebas Neue',sans-serif; font-size:26px; min-width:30px; text-align:center; color:var(--muted); }
.p4p-rank.g1{ color:var(--gold); }
.p4p-name{ font-weight:700; font-size:16px; flex:1; }
.vote-btn{
  font-family:'Bebas Neue',sans-serif; font-size:14px; letter-spacing:1.5px;
  padding:7px 14px; background:linear-gradient(135deg,var(--pi),#4c1d95);
  border:none; border-radius:6px; color:#fff; cursor:pointer;
}

.overlay{
  position:fixed; inset:0; z-index:200;
  background:var(--overlay-bg); backdrop-filter:blur(8px);
  display:flex; align-items:center; justify-content:center; padding:16px;
  opacity:0; pointer-events:none; transition:opacity .2s;
}
.overlay.open{ opacity:1; pointer-events:all; }
.modal{
  background:var(--card2); border:1px solid rgba(240,180,41,0.25);
  border-radius:16px; padding:28px; max-width:400px; width:100%; position:relative;
}
.modal-x{ position:absolute;top:12px;right:14px;background:none;border:none;color:var(--muted);font-size:20px;cursor:pointer; }
.wallet-box{
  background:var(--wallet-bg); border-radius:8px; padding:11px 13px;
  margin-bottom:16px; font-size:12px; color:var(--muted2);
}
.wallet-addr{ font-family:'Share Tech Mono',monospace; color:var(--pi3); font-size:11px; word-break:break-all; margin-top:3px; }
.confirm-btn{
  width:100%; font-family:'Bebas Neue',sans-serif; font-size:19px; letter-spacing:3px;
  padding:13px; background:linear-gradient(135deg,var(--pi),#4c1d95);
  border:none; border-radius:8px; color:#fff; cursor:pointer;
}
</style>
</head>
<body>
<div class="bg-glow"></div>

<header>
  <div class="header-top">
    <div class="pi-tag"><div class="pi-dot"></div>Pi Network</div>
    <div class="header-controls">
      <select class="lang-select" id="langSelect">
        <option value="en">🇬🇧 EN</option>
        <option value="ru">🇷🇺 RU</option>
      </select>
      <button class="theme-toggle" onclick="toggleTheme()">
        <div class="knob" id="themeKnob">🌙</div>
      </button>
    </div>
  </div>
  <h1>UFC P4P</h1>
  <div class="h1-sub">Fan Rating System</div>
</header>

<nav class="nav">
  <div class="nav-inner">
    <button class="nav-btn active" onclick="showPage('p4p', this)">🏆 P4P TOP-15</button>
  </div>
</nav>

<div class="page p4p-page active" id="page-p4p">
  <div class="section-label">Men's P4P · Fan Votes</div>
  <div class="p4p-list" id="p4p-list"></div>
</div>

<div class="overlay" id="overlay">
  <div class="modal">
    <button class="modal-x" onclick="closeModal()">✕</button>
    <div class="modal-fighter-name" id="m-name" style="text-align:center; font-family:'Bebas Neue'; font-size:24px; margin-bottom:10px;">—</div>
    <div class="wallet-box">
      <span>Отправьте 1 Pi на адрес кошелька:</span>
      <div class="wallet-addr">GBUZ7CAVJOTI5VWSJ3TLKADK2XOXOK6ZZPBZ7T72PBW5WM6PP7R7BX7R</div>
    </div>
    <button class="confirm-btn" onclick="confirmVote()">CONFIRM VOTE — 1π</button>
  </div>
</div>

<script>
const fighters = [
  { name: "Islam Makhachev", rank: 1, photo: "img/islam.png", weight: "Lightweight" },
  { name: "Jon Jones", rank: 2, photo: "img/jones.png", weight: "Heavyweight" },
  { name: "Alex Pereira", rank: 3, photo: "img/pereira.png", weight: "Light Heavyweight" },
  { name: "Ilia Topuria", rank: 4, photo: "img/topuria.png", weight: "Featherweight" }
];

function renderP4P() {
  const list = document.getElementById('p4p-list');
  list.innerHTML = fighters.map(f => `
    <div class="p4p-card ${f.rank === 1 ? 'rank-1' : ''}">
      <div class="p4p-rank ${f.rank === 1 ? 'g1' : ''}">${f.rank}</div>
      <div class="p4p-photo">
        <img src="${f.photo}" onerror="this.parentElement.innerHTML='<div class=\"no-photo\">🥊</div>'">
      </div>
      <div class="p4p-name">${f.name}</div>
      <button class="vote-btn" onclick="openModal('${f.name}')">VOTE</button>
    </div>
  `).join('');
}

function openModal(name) {
  document.getElementById('m-name').innerText = name;
  document.getElementById('overlay').classList.add('open');
}

function closeModal() {
  document.getElementById('overlay').classList.remove('open');
}

function toggleTheme() {
  const html = document.documentElement;
  const knob = document.getElementById('themeKnob');
  if (html.getAttribute('data-theme') === 'dark') {
    html.setAttribute('data-theme', 'light');
    knob.innerText = '☀️';
  } else {
    html.setAttribute('data-theme', 'dark');
    knob.innerText = '🌙';
  }
}

function confirmVote() {
  alert("Кошелек для оплаты: GBUZ7CAVJOTI5VWSJ3TLKADK2XOXOK6ZZPBZ7T72PBW5WM6PP7R7BX7R. Транзакция будет добавлена после подтверждения в сети Pi.");
  closeModal();
}

document.addEventListener('DOMContentLoaded', renderP4P);
</script>
</body>
</html>
